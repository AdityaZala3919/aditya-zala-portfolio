# Use Node.js image
FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package files first (for caching)
COPY frontend/package*.json ./

# Install dependencies
RUN npm install

# Copy rest of frontend code
COPY frontend/ .

# Expose dev server port (Vite default 5173)
EXPOSE 5173

# Run dev server with --host to allow external connections in Docker
CMD ["npm", "run", "dev", "--", "--host"]